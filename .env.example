DJINNI_BASE_URL=https://djinni.co
SCRAPE_INTERVAL_MIN=60
DJINNI_KEYWORDS=
MAX_PAGES=
REQUEST_DELAY_SEC=2.0
DB_PATH=./liza.db
DJINNI_COOKIE=
# USER_AGENT=        # optional; config.py provides a sensible default
ENABLE_SCHEDULER=true
SCRAPE_ON_STARTUP=true

# OpenRouter (job-hunter LLM matching). Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
LLM_MODEL_SCORE=openai/gpt-4o-mini
